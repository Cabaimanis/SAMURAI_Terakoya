function myFunction() {
  // 朝の挨拶を出力する関数を定義する
  const sayGoodMorning = () => {
    console.log('おはようございます！');
    console.log('昨日はよく眠れましたか？');
    console.log('今日も１日頑張りましょう！');
  }

  // 夜の挨拶を出力する関数を定義する
  const sayGoodEvening = () => {
    console.log('こんばんは！');
    console.log('今日も１日お疲れさまでした。');
  }
  
  // 朝の挨拶を出力する関数を呼び出す
  sayGoodMorning();

  // 夜の挨拶を出力する関数を呼び出す
  sayGoodEvening();

  // 与えられた引数priceに送料を加算し、その値を出力する関数を定義する
  const calculateTotal = (price) => {
    console.log(price + 500 + '円');
  }

  // 関数を呼び出し、引数として購入金額を渡す
  calculateTotal(1200);
  }

  // 与えられた引数priceと引数shippingFeeを加算し、その値を出力する関数を定義する
  const addTwoArguments = (price, shippingFee) => {
    console.log(price + shippingFee + '円');
  }

  // 引数を呼び出し、引数として購入金額と送料を渡す
  addTwoArguments(1200, 500);

// 朝の挨拶を出力する関数を定義する
function sayGoodMorning(){
  console.log('おはようございます');
  console.log('昨日はよく眠れましたか？');
  console.log('今日も１日頑張りましょう！');
}

// 夜の挨拶を出力する関数を定義する
function sayGoodEvening(){
  console.log('こんばんは！');
  console.log('今日も１日お疲れさまでした。');
}

  // 与えられた引数priceに送料を加算し、その値を出力する関数を定義する
  function calculateTotal(price){
    console.log(price + 500 + '円');
  }
